DATABASE_URL="postgresql://postgres:password@localhost:5432/cms_db?schema=public"

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

PORT=3000
NODE_ENV=development

# "Sign in with Google" login/register flow.
# Setup: https://console.cloud.google.com/ -> OAuth consent screen -> Credentials
# -> OAuth client ID (Web application) -> add GOOGLE_OAUTH_LOGIN_CALLBACK_URL
# under Authorized redirect URIs. Leave blank to disable Google login.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_LOGIN_CALLBACK_URL=http://localhost:8888/auth/google/callback
FRONTEND_URL=http://localhost:5173
